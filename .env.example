# ─────────────────────────────────────────────────────────────────────────────
# MapleZhuan — Environment Variables Template
#
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in every value from the Firebase project console accordingly
# 3. NEVER commit .env.local to git!!!!!!!!!!
# ─────────────────────────────────────────────────────────────────────────────

# Firebase Configuration
# Get these from: Firebase Console → Project Settings → The corresponding Web app → SDK config
# fill in accordingly
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional: Firebase Analytics (can be left blank to disable)
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Optional: Platform support contact email (defaults to hello@maplezhuan.ca)
# this would be showed in the support from 'My Profile' (我的) page
# this email would override the maplezhuan/src/lib/constants.ts constant
NEXT_PUBLIC_SUPPORT_EMAIL=
